#!/bin/bash

set -ex
test -d "$1"

WORKSPACE=$(cd "$1" && pwd)
test "$WORKSPACE" != "$HOME"
shift 1

docker run --rm \
    --user $(id -u):$(id -g) \
    --network host \
    -v /etc/passwd:/etc/passwd:ro \
    -v /etc/group:/etc/group:ro \
    -v $HOME/.pi:$HOME/.pi \
    -v $WORKSPACE:$WORKSPACE \
    -w $WORKSPACE \
    $([[ "$*" =~ -p ]] || echo -it) \
    wizawu/agent:latest pi -a "$@"
