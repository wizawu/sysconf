#!/bin/bash

set -ex
test -d "$1"

WORKSPACE=$(cd "$1" && pwd)
test "$WORKSPACE" != "$HOME"
shift 1

docker run --rm -it \
    --user $(id -u):$(id -g) \
    --network host \
    -v /etc/passwd:/etc/passwd:ro \
    -v /etc/group:/etc/group:ro \
    -v $HOME/.kimi-code:$HOME/.kimi-code \
    -v $WORKSPACE:$WORKSPACE \
    -w $WORKSPACE \
    wizawu/agent:latest kimi --yolo "$@"
