#!/bin/bash

set -ex
if [[ -z $1 ]]; then
  if [[ $PWD = $HOME ]]; then
    WORKSPACE=$HOME/tmp
  else
    WORKSPACE=$PWD
  fi
else
  test -d "$1"
  WORKSPACE=$(cd "$1" && pwd)
  test "$WORKSPACE" != "$HOME"
  shift 1
fi

docker run --rm \
    --user $(id -u):$(id -g) \
    --network host \
    -v /etc/passwd:/etc/passwd:ro \
    -v /etc/group:/etc/group:ro \
    -v $HOME/.kimi-code:$HOME/.kimi-code \
    -v $WORKSPACE:$WORKSPACE \
    -w $WORKSPACE \
    $([[ "$*" =~ -p ]] || echo -it) \
    wizawu/agent:latest kimi $([[ "$*" =~ -p ]] || echo --yolo) "$@"
